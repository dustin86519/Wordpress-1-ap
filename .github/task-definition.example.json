{
  "family": "wp-ap-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::264621616114:role/service-role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::264621616114:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "wp-ap",
      "image": "264621616114.dkr.ecr.ap-east-2.amazonaws.com/wordpress-ap-deploy:latest",
      "portMappings": [
        {
          "containerPort": 9000,
          "protocol": "tcp"
        }
      ],
      "essential": true,

      "secrets": [
        {
          "name": "DB_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:ap-east-2:264621616114:secret:WP-db-secrets-ZiMbmV:DB_PASSWORD::"
        },
        {
          "name": "WP_AUTH_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-east-2:264621616114:secret:WP-db-secrets-ZiMbmV:WP_AUTH_KEY::"
        },
        {
          "name": "WP_SECURE_AUTH_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-east-2:264621616114:secret:WP-db-secrets-ZiMbmV:WP_SECURE_AUTH_KEY::"
        },
        {
          "name": "WP_LOGGED_IN_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-east-2:264621616114:secret:WP-db-secrets-ZiMbmV:WP_LOGGED_IN_KEY::"
        },
        {
          "name": "WP_NONCE_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-east-2:264621616114:secret:WP-db-secrets-ZiMbmV:WP_NONCE_KEY::"
        },
        {
          "name": "WP_AUTH_SALT",
          "valueFrom": "arn:aws:secretsmanager:ap-east-2:264621616114:secret:WP-db-secrets-ZiMbmV:WP_AUTH_SALT::"
        },
        {
          "name": "WP_SECURE_AUTH_SALT",
          "valueFrom": "arn:aws:secretsmanager:ap-east-2:264621616114:secret:WP-db-secrets-ZiMbmV:WP_SECURE_AUTH_SALT::"
        },
        {
          "name": "WP_LOGGED_IN_SALT",
          "valueFrom": "arn:aws:secretsmanager:ap-east-2:264621616114:secret:WP-db-secrets-ZiMbmV:WP_LOGGED_IN_SALT::"
        },
        {
          "name": "WP_NONCE_SALT",
          "valueFrom": "arn:aws:secretsmanager:ap-east-2:264621616114:secret:WP-db-secrets-ZiMbmV:WP_NONCE_SALT::"
        }
      ],
      "environment": [
        { "name": "DB_NAME",        "value": "wordpress_db" },
        { "name": "DB_USER",        "value": "wp_user" },
        { "name": "DB_MASTER_HOST", "value": "wordpress-db-master.cns4yqu06hhv.ap-east-2.rds.amazonaws.com" },
        { "name": "DB_SLAVE_HOST",  "value": "wordpress-db-slave.cns4yqu06hhv.ap-east-2.rds.amazonaws.com" },
        { "name": "AWS_S3_BUCKET",  "value": "wp-access-file-bucket" }
      ],

      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/wp-ap",
          "awslogs-region": "ap-east-2",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
