# 複製此檔為 .env，填入實際值，絕對不可 commit .env

# 資料庫
DB_NAME=wordpress_db
DB_USER=wp_user
DB_PASSWORD=
DB_MASTER_HOST=127.0.0.1
DB_SLAVE_HOST=127.0.0.1

# S3
AWS_S3_BUCKET=your-bucket-name

# WordPress Salts（可用 https://api.wordpress.org/secret-key/1.1/salt/ 產生）
WP_AUTH_KEY=
WP_SECURE_AUTH_KEY=
WP_LOGGED_IN_KEY=
WP_NONCE_KEY=
WP_AUTH_SALT=
WP_SECURE_AUTH_SALT=
WP_LOGGED_IN_SALT=
WP_NONCE_SALT=
